# Environment Configuration
# Copy this file to .env for Docker / backend and to .env.local for local frontend-only work

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend auth secret (required outside development)
JWT_SECRET=change-me-to-a-long-random-secret

# Allowed frontend origins for the backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.119:3000

# Temp file retention in seconds (default 10 minutes)
JOB_RESULT_TTL_SECONDS=600
TEMP_FILE_TTL_SECONDS=600
MIN_FREE_DISK_MB=1024
MAX_DISK_USAGE_PERCENT=90

# App Settings
NEXT_PUBLIC_APP_NAME=ToolBox Pro
NEXT_PUBLIC_APP_VERSION=2.0.0

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_PWA=true
