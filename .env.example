# Environment Configuration
# Copy this file to .env for Docker / backend and to .env.local for local frontend-only work

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend auth secret (required outside development)
JWT_SECRET=change-me-to-a-long-random-secret

# Temp file retention in seconds (default 10 minutes)
JOB_RESULT_TTL_SECONDS=600
TEMP_FILE_TTL_SECONDS=600

# App Settings
NEXT_PUBLIC_APP_NAME=ToolBox Pro
NEXT_PUBLIC_APP_VERSION=2.0.0

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_PWA=true
